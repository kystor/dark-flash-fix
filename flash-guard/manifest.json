{
  "manifest_version": 3,
  "name": "FlashGuard - 防闪白遮罩",
  "version": "1.1.0",
  "description": "在网页加载时注入暗色遮罩，防止出现白色闪屏，加载完成后平滑淡出。支持白名单与切回标签触发效果。",

  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["flash-guard-early.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "FlashGuard 设置"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
